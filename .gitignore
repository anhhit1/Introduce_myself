# ---- Biến môi trường & API keys (QUAN TRỌNG) ----
.env
.env.*
*.env
!.env.example 

# ---- Hướng dẫn ----
how code work.txt
how to deploy.txt

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
*.whl

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.env.bak

# ---- Vector store / database ----
