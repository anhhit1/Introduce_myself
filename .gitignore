vectorstore/
*.db
*.sqlite
*.sqlite3

# ---- Logs ----
*.log
error.log
logs/

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Node.js (nếu có) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

